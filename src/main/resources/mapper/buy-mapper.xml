<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 해당 파일에 모든 쿼리문을 작성 -->
<!-- namespace에는 xml파일과 연결할 Mapper interface 파일명을 패키지를 포함하여 적어주세요 -->
<mapper namespace="com.green.book_shop.buy.mapper.BuyMapper">
	<resultMap id="buy" type="com.green.book_shop.buy.dto.BuyDTO">
        <id column="BUY_NUM" property="buyNum"/>
        <result column="BUY_PRICE" property="buyPrice" />
        <result column="MEM_EMAIL" property="memEmail" />
        <result column="BUY_DATE" property="buyDate" />

        <collection property="detailList" resultMap="buyDetail" />
    </resultMap>

    <resultMap id="buyDetail" type="com.green.book_shop.buy.dto.BuyDetailDTO">
        <id column="BUY_DETAIL_NUM" property="buyDetailNum"/>
        <result column="BOOK_NUM" property="bookNum" />
        <result column="BUY_CNT" property="buyCnt" />
        <result column="BUY_NUM" property="buyNum" />

        <association property="bookDTO" resultMap="com.green.book_shop.book.mapper.BookMapper.book"/>

    </resultMap>

    <!--구매 등록(SHOP_BUY) 쿼리-->
    <!--useGeneratedKeys="true" : auto_increment된 key를 insert시 사용하겠다는 의미-->
    <!--keyProperty="PK 컬럼명" : 이 쿼리의 빈 값을 채우기 위해 가져온 객체(buyDTO)의
    buyNum변수에 생성된 key를 넣어주겠다는 의미-->
    <insert id="insertBuy" useGeneratedKeys="true" keyProperty="buyNum">
        INSERT INTO SHOP_BUY (
            BUY_PRICE
            , MEM_EMAIL
        )
        VALUES (
            #{buyPrice}
            , #{memEmail}
        )
    </insert>

    <insert id="insertBuyDetail">
        INSERT INTO BUY_DETAIL (
            BOOK_NUM
            , BUY_CNT
            , BUY_NUM
        ) VALUES
        <foreach collection="detailList" item="detail" separator="," >
            (
                #{detail.bookNum}
                , #{detail.buyCnt}
                , #{buyNum}
            )
        </foreach>

    </insert>

    <!--구매 목록 상세 조회-->
    <select id="selectBuyList" resultMap="buy">
        SELECT B.BUY_NUM
            , BUY_PRICE
            , BUY_DATE
            , BUY_CNT
            , BOOK_TITLE
            , BOOK_PRICE
            , UPROAD_FILE_NAME
        FROM SHOP_BUY B
        INNER JOIN BUY_DETAIL D
        ON B.BUY_NUM = D.BUY_NUM
        INNER JOIN SHOP_BOOK BOOK
        ON D.BOOK_NUM = BOOK.BOOK_NUM
        INNER JOIN BOOK_IMG I
        ON I.BOOK_NUM = BOOK.BOOK_NUM
        WHERE IS_MAIN = 'Y'
        AND MEM_EMAIL = #{memEmail}
        ORDER BY BUY_DATE DESC
    </select>

    <!--오늘의 주문 & 매출금액 건수 조회-->
    <select id="todayOrder" resultMap="buy">
        SELECT SUM(BUY_NUM)
            , SUM(BUY_PRICE)
        FROM  SHOP_BUY
        WHERE DATE(BUY_DATE) = DATE(SYSDATE())
    </select>





</mapper>































